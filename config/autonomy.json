{
  "_meta": {
    "version": "1.0.0",
    "description": "KORGAN AI — Autonomy Level Configuration"
  },
  "current_level": 3,
  "levels": {
    "0": {
      "name": "MANUAL",
      "description": "All actions require explicit user approval",
      "behavior": {
        "auto_execute": false,
        "suggest": true,
        "show_preview": true,
        "require_approval_for_all": true,
        "notification_mode": "immediate",
        "can_read": true,
        "can_write": false,
        "can_execute_commands": false
      }
    },
    "1": {
      "name": "SUGGESTION",
      "description": "System analyzes and suggests plans with previews, waits for approval",
      "behavior": {
        "auto_execute": false,
        "suggest": true,
        "show_preview": true,
        "require_approval_for_all": true,
        "notification_mode": "immediate",
        "can_read": true,
        "can_write": false,
        "can_execute_commands": false,
        "batch_suggestions": true,
        "max_suggestions_queue": 10
      }
    },
    "2": {
      "name": "CONDITIONAL_AUTONOMY",
      "description": "Allowed actions execute automatically; approval_required actions need confirmation",
      "behavior": {
        "auto_execute_allowed": true,
        "auto_execute_approval_required": false,
        "auto_execute_forbidden": false,
        "suggest": true,
        "show_preview": true,
        "notification_mode": "after_action",
        "notification_batch_interval_minutes": 5,
        "rollback_window_minutes": 5,
        "can_read": true,
        "can_write": true,
        "can_execute_commands": true,
        "max_auto_actions_per_hour": 50
      }
    },
    "3": {
      "name": "FULL_AUTONOMOUS",
      "description": "All allowed actions are automatic; approval actions auto-approved at high confidence",
      "behavior": {
        "auto_execute_allowed": true,
        "auto_execute_approval_required": true,
        "auto_execute_forbidden": false,
        "approval_confidence_threshold": 0.9,
        "suggest": false,
        "show_preview": false,
        "notification_mode": "batch",
        "notification_batch_interval_minutes": 15,
        "rollback_window_minutes": 10,
        "can_read": true,
        "can_write": true,
        "can_execute_commands": true,
        "max_auto_actions_per_hour": 200,
        "auto_rollback_on_error": true,
        "stop_on_consecutive_errors": 3,
        "escalate_to_manual_on_stop": true
      }
    }
  },
  "level_change_rules": {
    "requires_authentication": true,
    "allowed_transitions": {
      "0": [
        1
      ],
      "1": [
        0,
        2
      ],
      "2": [
        0,
        1,
        3
      ],
      "3": [
        0,
        1,
        2
      ]
    },
    "cooldown_after_crisis_minutes": 30,
    "auto_downgrade_on_crisis": true,
    "auto_downgrade_target": 0
  },
  "scheduling": {
    "enabled": false,
    "rules": [
      {
        "time_range": "00:00-08:00",
        "max_level": 1,
        "reason": "Night hours — reduced autonomy"
      },
      {
        "time_range": "08:00-23:00",
        "max_level": 3,
        "reason": "Active hours — full capability"
      }
    ]
  }
}