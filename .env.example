# =============================================================================
# KORGAN AI — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Database ---
DB_PASSWORD=your_secure_password_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OWNER_TELEGRAM_ID=your_telegram_user_id

# --- Cloud LLM (optional, for complex tasks) ---
CLAUDE_API_KEY=
OPENAI_API_KEY=

# --- Whisper ---
WHISPER_MODEL_SIZE=medium

# --- Face Recognition ---
FACE_THRESHOLD=0.6

# --- Autonomy ---
AUTONOMY_LEVEL=0

# --- N8N ---
N8N_USER=admin
N8N_PASSWORD=your_n8n_password

# --- Logging ---
LOG_LEVEL=INFO
