# --- Surveillance AI Environment Configuration ---
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=your_secure_password_here

# Flask Backend
SECRET_KEY=your-random-secret-key-here
LOG_LEVEL=INFO

# Face Recognition
FACE_MODEL=buffalo_l
FACE_THRESHOLD=0.5

# Internal API Key (shared between backend and telegram bot)
INTERNAL_API_KEY=generate-a-random-key-here

# Telegram Bot (Saphena AI Assistant)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_BOT_PASSWORD=your_secure_bot_password
SESSION_TIMEOUT=3600
